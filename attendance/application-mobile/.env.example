# Attendance Mobile - Environment Variables
# Copy to .env and fill in your values

# Backend API URL (use your local IP for device testing)
API_BASE_URL=http://192.168.1.181:3002/api

# App configuration
APP_NAME=Attendance Mobile
APP_VERSION=1.0.0+1

# Feature flags
ENABLE_BIOMETRIC=true
ENABLE_PUSH_NOTIFICATIONS=false

# Timeouts (milliseconds)
API_TIMEOUT=30000
API_RETRY_COUNT=3